{
  "manifest_version": 2,
  "name": "Momus - Google Maps Review Analyzer",
  "version": "1.17.1",
  "description": "Synthesize hundreds of Google Maps reviews in seconds. Spot patterns, red flags, and make better decisions.",
  "browser_specific_settings": {
    "gecko": {
      "id": "momus_gmaps_review_analizer@momus.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/maps/*"],
      "js": ["content/keywords.js", "content/scraper.js", "content/content.js"]
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "web_accessible_resources": [
    "lib/typo.js",
    "dictionaries/*"
  ]
}
